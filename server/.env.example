# Copy to `.env` and fill in. `.env` is gitignored — never commit real values.

# From @BotFather when you create the bot (/newbot)
TELEGRAM_BOT_TOKEN=123456789:AA...your-token...

# Your numeric chat id. Easiest way to find it:
#   1. Send any message to your new bot in Telegram.
#   2. Open https://api.telegram.org/bot<TOKEN>/getUpdates in a browser.
#   3. Copy result[0].message.chat.id
TELEGRAM_CHAT_ID=123456789

# Optional
PORT=8787
# Comma-separated allow-list, or "*" for any origin.
ALLOWED_ORIGIN=https://cv.shrek-labs.dev
MAX_REQUESTS_PER_MIN=5
